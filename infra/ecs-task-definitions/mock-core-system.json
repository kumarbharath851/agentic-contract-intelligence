{
  "family": "aci-mock-core",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::866543941893:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::866543941893:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "mock-core-system",
      "image": "866543941893.dkr.ecr.us-east-1.amazonaws.com/aci-mock-core-system:latest",
      "portMappings": [{ "containerPort": 8084, "protocol": "tcp" }],
      "essential": true,
      "environment": [
        { "name": "SERVER_PORT", "value": "8084" },
        { "name": "SPRING_PROFILES_ACTIVE", "value": "prod" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/aci-mock-core",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8084/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
