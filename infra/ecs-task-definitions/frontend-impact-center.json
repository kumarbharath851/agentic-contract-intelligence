{
  "family": "aci-frontend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::866543941893:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::866543941893:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "frontend-impact-center",
      "image": "866543941893.dkr.ecr.us-east-1.amazonaws.com/aci-frontend-impact-center:latest",
      "portMappings": [{ "containerPort": 80, "protocol": "tcp" }],
      "essential": true,
      "environment": [
        { "name": "API_BASE_URL", "value": "http://aci-experience-gateway:8082" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/aci-frontend",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost/ || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      }
    }
  ]
}
