{
  "$schema": "https://json.schemastore.org/angular.json",
  "version": 1,
  "projects": {
    "impact-center": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "aci",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/impact-center",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "assets": ["src/favicon.ico", "src/assets"],
            "styles": ["src/styles.css"]
          },
          "configurations": {
            "production": {
              "optimization": true,
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "buildTarget": "impact-center:build:development"
          },
          "configurations": {
            "production": {
              "buildTarget": "impact-center:build:production"
            },
            "development": {
              "buildTarget": "impact-center:build:development"
            }
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
